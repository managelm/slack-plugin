# Slack App credentials (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# ManageLM portal
MANAGELM_PORTAL_URL=https://app.managelm.com
MANAGELM_API_KEY=mlm_ak_...

# Webhook receiver
PORT=3100

# Channel routing (optional — defaults to posting in the channel where /managelm was used)
# Single Slack channel ID for each event category
SLACK_CHANNEL_ALERTS=        # agent.offline, task.failed
SLACK_CHANNEL_INFO=          # agent.enrolled, agent.approved, agent.online, task.completed

# Portal URL for "View in portal" links
MANAGELM_PORTAL_PUBLIC_URL=https://app.managelm.com
